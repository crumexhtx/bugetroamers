# Planora environment
# Required for production builds. Use the deployed origin without a trailing slash.
# Local development falls back to http://localhost:5173 when this is unset.
VITE_SITE_URL=https://your-project.vercel.app

# Optional browser error reporting. Sentry initializes only when this is set.
# VITE_SENTRY_DSN=https://public-key@o0.ingest.sentry.io/0

# Required by the server-side /api/contact function.
RESEND_API_KEY=re_your_api_key
CONTACT_TO_EMAIL=contact@example.com
CONTACT_FROM_EMAIL=Planora <contact@your-verified-domain.example>

# Optional server-side error reporting for unexpected contact API failures.
# SENTRY_DSN=https://public-key@o0.ingest.sentry.io/0

# Optional newsletter webhook / form endpoint.
# VITE_NEWSLETTER_ENDPOINT=https://example.com/api/newsletter
